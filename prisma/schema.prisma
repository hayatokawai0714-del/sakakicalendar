generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ShipmentType {
  REGULAR
  SPOT
}

enum RecurrenceInterval {
  WEEKLY
  BIWEEKLY
}

model Destination {
  id          Int      @id @default(autoincrement())
  name        String
  address     String?
  phone       String?
  contactName String?
  email       String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shipments         Shipment[]
  recurringShipment RecurringShipment[]
}

model UnitSetting {
  id        Int      @id @default(autoincrement())
  category  String
  name      String
  sortOrder Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shipment {
  id            Int          @id @default(autoincrement())
  date          DateTime
  shipmentType  ShipmentType
  destinationId Int
  spec          String
  quantity      Float
  unit          String
  memo          String?
  updatedBy     String
  updatedAt     DateTime     @updatedAt

  destination Destination @relation(fields: [destinationId], references: [id])
}

model RecurringShipment {
  id            Int                @id @default(autoincrement())
  destinationId Int
  interval      RecurrenceInterval
  weekday       Int
  spec          String
  quantity      Float
  unit          String
  startDate     DateTime
  endDate       DateTime?
  memo          String?
  updatedBy     String
  updatedAt     DateTime           @updatedAt

  destination Destination @relation(fields: [destinationId], references: [id])
}

model Event {
  id        Int      @id @default(autoincrement())
  date      DateTime
  time      String?
  title     String
  memo      String?
  updatedBy String
  updatedAt DateTime @updatedAt
}

model Memo {
  id        Int      @id @default(autoincrement())
  date      DateTime
  content   String
  priority  Int      @default(2)
  updatedBy String
  updatedAt DateTime @updatedAt
}
